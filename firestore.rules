rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Admin log is write-only from server (Admin SDK bypasses rules), no client access
    match /adminLogs/{logId} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /entries/{entryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        
        match /analysis/{analysisId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
      
      match /goals/{goalId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /journeys/{journeyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /achievements/{achievementId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /connections/{connectionId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Only server can write connections
      }
      
      match /weeklyReports/{reportId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Only server can write reports
      }
    }
  }
}
