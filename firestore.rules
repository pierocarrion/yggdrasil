rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin log is write-only from server (Admin SDK bypasses rules), no client access
    match /adminLogs/{logId} {
      allow read, write: if false;
    }

    // Top-level Subscriptions (client read-only)
    match /subscriptions/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /processedEvents/{eventId} {
      allow read, write: if false;
    }

    // Top-level Feedback
    match /feedback/{feedbackId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /users/{userId} {
      // Server-controlled fields the client must never set or mutate. The webhook
      // resolves users by stripeCustomerId and grants entitlements by tier, so a
      // client that could write these could hijack another account's billing.
      function protectedUserFields() {
        return ['stripeCustomerId', 'tier', 'entryCount', 'analyticsClientId', 'admin'];
      }

      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.keys().hasAny(protectedUserFields());
      allow update: if request.auth != null
        && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedUserFields());
      allow delete: if request.auth != null && request.auth.uid == userId;

      match /entries/{entryId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null
          && request.auth.uid == userId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['insightGated']);
        
        match /analysis/{analysisId} {
          allow read: if request.auth != null && request.auth.uid == userId;
          allow write: if false;
        }
      }
      
      match /roots/{rootId} {
        // gated/embedding fields are server-set (mirrors insightGated on
        // entries) so the free-tier cap can't be cleared client-side.
        function protectedRootFields() {
          return ['gated', 'embedding', 'embeddingGeneratedAt'];
        }

        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.auth.uid == userId
          && !request.resource.data.keys().hasAny(protectedRootFields());
        allow update: if request.auth != null
          && request.auth.uid == userId
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(protectedRootFields());

        match /events/{eventId} {
          allow read, create, delete: if request.auth != null && request.auth.uid == userId;
          allow update: if false; // journey events are immutable facts
        }
      }

      match /rootSuggestions/{suggestionId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if false; // server only (Admin SDK bypasses rules)
        allow update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'resolvedAt']);
      }

      match /achievements/{achievementId} {
        allow read, update, delete: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null && request.auth.uid == userId;
      }
      
      match /connections/{connectionId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Only server can write connections
      }
      
      match /weeklyReports/{reportId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false; // Only server can write reports
      }
      
      match /settings/{settingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
