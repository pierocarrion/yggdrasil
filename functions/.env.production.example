# ─── Functions runtime secrets (Secret Manager) ───────────────────────────────
# These are NOT set here — they are declared via defineSecret() / process.env and
# resolved from Secret Manager at runtime. Ensure the following secrets exist in
# each target project (yggdrasil-dev, yggdrasil-prod):
#   STRIPE_SECRET_KEY        → secret: stripe-secret-key
#   STRIPE_WEBHOOK_SECRET    → secret: stripe-webhook-secret
#   GEMINI_API_KEY           → secret: gemini-api-key  (declared via defineSecret in lib/gemini.ts)
#
# TODO(app): declare STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET via defineSecret()
# (functions/src/lib/gemini.ts shows the pattern) so 2nd-gen functions mount them
# automatically. Until then, set them with:
#   firebase functions:secrets:set STRIPE_SECRET_KEY   --project=<env>
#   firebase functions:secrets:set STRIPE_WEBHOOK_SECRET --project=<env>

# ─── Functions non-secret config (set with firebase functions:config or deploy env) ──
APP_URL=https://yggdrasil-prod.run.app
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_ANNUAL=
STRIPE_PRICE_ID_LIFETIME=
ANALYTICS_DEBUG=false
